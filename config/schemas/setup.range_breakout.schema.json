{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "setup.range_breakout.schema.json",
  "title": "Range Breakout Setup",
  "type": "object",
  "required": ["range"],
  "properties": {
    "range": {
      "type": "object",
      "required": ["high", "low"],
      "properties": {
        "high": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "low": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "min_days_inside_range": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
